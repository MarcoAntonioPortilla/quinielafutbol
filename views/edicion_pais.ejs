<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Edición País</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body>
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <script>
                window.location.href = "/inicio";
            </script>
        <%}%>


        <% if(process.env.MENSAJE !== ''){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- process.env.MENSAJE %>
            </div>
        <% } %>


        <% if(typeof error !== 'undefined'){ %>
            <div class="alert alert-danger" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
                </svg>
                <strong>Error: </strong><%- error %>
            </div>
        <% } %>


        <% if(typeof pais_Mod !=='undefined'){ %>
            <input id="banderaModal" name="banderaModal" type="hidden" value="Activo">
        <% }else { %>
            <input id="banderaModal" name="banderaModal" type="hidden" value="">
        <% } %> 


       
        <div class="container-fluid">
            <div class="row mt-5">
                <div class="col-md-3">

                </div>
                <div class="col-md-6">
                    <div class="table-responsive"> 
                        <table class="table table-striped table-hover table-sm">
                            <thead class="table-dark text-center">
                                <tr>
                                    <th>Id</th>
                                    <th>Nombre</th>
                                    <th>Archivo</th>
                                    <th>Bandera</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(data){
                                    for(var i = 0; i < data.length; i++){ %>
                                        <tr>
                                            <td> <%= data[i].idpais %> </td>
                                            <td> <%= data[i].nombre %> </td>
                                            <td> <%= data[i].archivo %> </td>
                                            <td> 
                                                <img src="../assets/img/<%= data[i].archivo %>" width="80" alt="logo"> 
                                            </td>
                                            <td>
                                                <div class="alineacionCentrada">
                                                    <a href="/actualizar_pais/<%= data[i].idpais %>" class="tamanoBoton btn btn-primary">Actualizar</a> 
                                                    <button class="botonEliminar tamanoBoton btn btn-danger" id="<%= data[i].idpais %>">Eliminar</button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-3">
                    
                </div>
            </div>
        </div>
        





        <!-- Modal -->
        <% if(typeof pais_Mod !=='undefined'){ %>

            <form action="/registrar_cambios_pais/<%= pais_Mod.idpais %>" method="POST" encType="multipart/form-data">
                <div class="modal fade" id="ModalEditarPais" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h1 class="modal-title fs-5" id="exampleModalLabel">Editar País</h1>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="form-group col-sm-4">
                                        <img src="../assets/img/<%= pais_Mod.archivo %>" width="80" alt="logo"> 
                                    </div>
                                    <div class="form-group col-sm-4">
                                        <input class="form-control mr-sm-2 mt-3" name="idpais" value="<%= pais_Mod.idpais %>" readonly>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="form-group col-sm-12">
                                        <input class="form-control mr-sm-2 mt-3" name="nombre" placeholder="Nombre" value="<%= pais_Mod.nombre %>" required>
                                    </div>
                                </div>
                                <div class="row">    
                                    <div class="form-group col-sm-12">
                                        <input class="form-control-file mt-3" type="file" name="archivo">
                                    </div>
                                    
                                </div>
                                
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                <button type="submit" class="btn btn-primary">Actualizar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
            
            <% } %>





    </body>



    <script>
        $(document).ready(function() {
            var vBanderaModal = $("#banderaModal").val();

            if(vBanderaModal !== ""){ 
                $('#ModalEditarPais').modal('toggle');
            }
        });


        $('.botonEliminar').click(function(){
            var vIndice = $(this).attr("id");
            var vCadena = "<a href=" + "/eliminar_pais/" + vIndice + ">Eliminar</a>";

            alertify.alert('Eliminar país', "¿Está seguro de eliminar este país? " + vCadena);
        });
    </script>


</html>