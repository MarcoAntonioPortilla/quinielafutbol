<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Edición Partido</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body>
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <script>
                window.location.href = "/inicio";
            </script>
        <%}%>


        <% if(typeof mensaje !== 'undefined'){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- mensaje %>
            </div>
        <% } %>


        <% if(typeof error !== 'undefined'){ %>
            <div class="alert alert-danger" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
                </svg>
                <strong>Error: </strong><%- error %>
            </div>
        <% } %>


        <% if(typeof partidoSel !=='undefined'){ %>
            <input id="banderaModal" name="banderaModal" type="hidden" value="Activo">
        <% }else { %>
            <input id="banderaModal" name="banderaModal" type="hidden" value="">
        <% } %> 
        
        
        
        <div class="container-fluid">
            <form action="/mostrar_partidos" method="post">
                <div class="form-group row mt-2">
                    <div class="col-md-3">

                    </div>
                    <div class="col-md-6">
                        <label class="mt-3" for="evento">Evento:</label>
                        <select class="form-control col-md-12" name="evento" required>
                            <option value=""> </option>
                            <% if(eventos){ 
                                for(var i = 0; i < eventos.length; i++){ %>
                                    <option value="<%= eventos[i].idevento %>"><%= eventos[i].nombre %></option>
                                <% } %>    
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3">

                    </div>
                </div>
                <div class="alineacionCentrada">
                    <input class="btn btn-primary mt-3" type="submit" value="Buscar">
                </div>
            </form>

            <div class="row mt-5">
                <div class="col-md-2">

                </div>
                <div class="col-md-8">
                    <div class="alineacionCentrada">
                        <div class="alert alert-light" role="alert"> 
                            <strong><h2><%- process.env.EVENTO_SEL_NOMBRE%></h2></strong>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">

                </div>
                
            </div>
            
            <div class="row">
                <div class="col-md-2">

                </div>
                <div class="col-md-8">
                    <div class="table-responsive"> 
                        <table class="table table-striped table-hover">
                            <thead class="table-dark text-center">
                                <tr>
                                    <th>Id</th>
                                    <th>Grupo</th>
                                    <th>Fecha</th>
                                    <th>Equipo</th>
                                    <th></th>
                                    <th>Equipo</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(typeof data != 'undefined'){
                                    for(var i = 0; i < data.length; i++){ %>
                                        <tr>
                                            <td> <%= data[i].idpartido %> </td>
                                            <td> <center><h2> <%= data[i].grupo %> </h2></center> </td>
                                            <td>
                                                <center>
                                                    <%= data[i].fecha.toLocaleDateString() %> <!--es-MX-->
                                                    <%= data[i].hora %> hrs.
                                                </center> 
                                            </td> 
                                            <td>
                                                <center>
                                                    <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo1 %>" alt="logo">
                                                    <br>
                                                    <strong> <%= data[i].nombre1 %> </strong>
                                                </center>
                                            </td>
                                            <td>
                                                <img src="../assets/img/vs3.png" width="80" alt="logo">
                                            </td>
                                            <td> 
                                                <center>
                                                    <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo2 %>" alt="logo"> 
                                                    <br>
                                                    <strong> <%= data[i].nombre2 %> </strong>
                                                </center>
                                            </td>
                                            <td>
                                                <a href="/actualizar_partido/<%= data[i].idpartido %>" class="tamanoBoton btn btn-primary">Actualizar</a> 
                                                <button class="botonEliminar tamanoBoton btn btn-danger" id="<%= data[i].idpartido %>">Eliminar</button>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-2">
                    
                </div>
            </div>
        </div>
        





        <!-- Modal -->
        <% if(typeof partidoSel !=='undefined'){ %>

            <form action="/registrar_cambios_partido/<%= partidoSel.idpartido %>" method="POST">
                <div class="modal fade" id="ModalEditarPartido" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h1 class="modal-title fs-5" id="exampleModalLabel">Editar Partido</h1>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row">
                                    <div class="form-group col-sm-5">
                                        <label class="mt-3" for="fecha">Fecha:</label>
                                        <input class="form-control mr-sm-2" name="fecha" type="text" placeholder="Fecha" value="<%= partidoSel.fecha.toLocaleDateString() %>" required>
                                    </div>
                                    <div class="form-group col-sm-4">
                                        <label class="mt-3" for="hora">Hora:</label>
                                        <input class="form-control mr-sm-2" name="hora" type="time" placeholder="Hora" value="<%= partidoSel.hora %>" required>
                                    </div>
                                    <div class="form-group col-sm-3">
                                        <label class="mt-3" for="grupo">Grupo:</label>
                                        <input class="form-control mr-sm-2" name="grupo" type="text" placeholder="Grupo" value="<%= partidoSel.grupo %>" required>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="form-group col-sm-12">
                                        <label class="mt-3" for="equipo1">Equipo 1:</label>
                                        <select class="form-control col-md-10" name="equipo1" required>
                                            <option value="<%= partidoSel.pais1 %>"><%= partidoSel.nombre1 %></option>

                                            <% if(paises){ 
                                                for(var i = 0; i < paises.length; i++){ %>
                                                    <option value="<%= paises[i].idpais %>"><%= paises[i].nombre %></option>
                                                <% } %>    
                                            <% } %>
                                        </select>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="form-group col-sm-12">
                                        <label class="mt-3" for="equipo1">Equipo 2:</label>
                                        <select class="form-control col-md-10" name="equipo2" required>
                                            <option value="<%= partidoSel.pais2 %>"><%= partidoSel.nombre2 %></option>

                                            <% if(paises){ 
                                                for(var i = 0; i < paises.length; i++){ %>
                                                    <option value="<%= paises[i].idpais %>"><%= paises[i].nombre %></option>
                                                <% } %>    
                                            <% } %>
                                        </select>
                                    </div>
                                </div>



                               
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                <button type="submit" class="btn btn-primary">Actualizar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
            
        <% } %>



        

        <script>
            $(document).ready(function() {
                var vBanderaModal = $("#banderaModal").val();

                if(vBanderaModal !== ""){ 
                    $('#ModalEditarPartido').modal('toggle');
                }
            });


            $('.botonEliminar').click(function(){
                var vIndice = $(this).attr("id");
                var vCadena = "<a href=" + "/eliminar_partido/" + vIndice + ">Eliminar</a>";

                alertify.alert('Eliminar partido', "¿Está seguro de eliminar este partido? " + vCadena);
            });
        </script>    
        
    </body>
</html>