<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alta Partido</title>
    <link rel="shortcut icon" href="assets/img/balon.png">
</head>
<body>
    <% if(process.env.TIPO_USUARIO === "admin"){ %>
        <%- include('partials/_header-admin') %>
    <%}else{%>    
        <script>
            window.location.href = "/inicio";
        </script>
    <%}%>   

    <% if(typeof alta !== 'undefined'){ %>
        <div class="alert alert-primary" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
            </svg>
            <strong>Mensaje: </strong><%- alta %>
        </div>
    <% } %>

   
    <div class="container-fluid">
        <div class="row">
            <div class="form-group col-md-3">
            
            </div>
            <div class="form-group col-md-6 mt-5">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title text-center">Alta Partido</h5>
                    </div>
                    <div class="card-body">
                        <form action="/alta_nuevo_partido" method="post">
                            <div class="form-group row"> 
                                <div class="col-md-12">
                                    <label class="mt-3" for="evento">Evento:</label>
                                    <select class="form-control col-md-10" name="evento" required>
                                        <% if(typeof eventoSel !== 'undefined'){ %>
                                            <option value="<%= eventoSel %>"><%= nombreEvento %></option>
                                        <% } %>

                                        <% if(eventos){ 
                                            for(var i = 0; i < eventos.length; i++){ %>
                                                <option value="<%= eventos[i].idevento %>"><%= eventos[i].nombre %></option>
                                            <% } %>    
                                        <% } %>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group row mt-2">
                                <div class="col-md-5">
                                    <label class="mt-3" for="fecha">Fecha:</label>
                                    <input class="form-control col-md-10" type="date" name="fecha" value="<%= process.env.FECHA %>" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="mt-3" for="hora">Hora:</label>
                                    <input class="form-control col-md-10" type="time" name="hora" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="mt-3" for="grupo">Grupo:</label>
                                    <input class="form-control col-md-10" name="grupo" placeholder="Grupo" value="<%= process.env.GRUPO %>" onKeyUp="this.value = this.value.toUpperCase();" required>
                                </div>
                            </div>
                            <div class="form-group row mt-2">
                                <div class="col-md-12">
                                    <label class="mt-3" for="equipo1">Equipo 1:</label>
                                    <select class="form-control col-md-10" name="equipo1" required>
                                        <% if(paises){ 
                                            for(var i = 0; i < paises.length; i++){ %>
                                                <option value="<%= paises[i].idpais %>"><%= paises[i].nombre %></option>
                                            <% } %>    
                                        <% } %>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group row mt-2">
                                <div class="col-md-12">
                                    <label class="mt-3" for="equipo2">Equipo 2:</label>
                                    <select class="form-control col-md-10" name="equipo2" required>
                                        <% if(paises){ 
                                            for(var i = 0; i < paises.length; i++){ %>
                                                <option value="<%= paises[i].idpais %>"><%= paises[i].nombre %></option>
                                            <% } %>    
                                        <% } %>
                                    </select>
                                </div>
                            </div>
                            <div class="alineacionCentrada">
                                <button type="submit" class="btn btn-primary row mt-2">Guardar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-3">
            
            </div>
        </div>
    </div>
</body>
</html>