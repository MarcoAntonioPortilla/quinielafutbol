<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
        <title>Cambio de Contraseña</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
       
        
    </head>
    <body class="body-contrasena">
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <%- include('partials/_header') %>
        <%}%>   


        <% if(typeof mensaje !== 'undefined'){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- mensaje %>
            </div>
        <% } %>


        <% if(typeof error !== 'undefined'){ %>
            <div class="alert alert-danger" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
                </svg>
                <strong>Error: </strong><%- error %>
            </div>
        <% } %>


        
        <% if(typeof data !== 'undefined'){ %>
        <div class="container">
            <div class="row">
                <div class="form-group col-md-3">
                
                </div>
                <div class="form-group col-md-6 mt-5">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title text-center">Cambio Usuario y Contraseña</h5>
                        </div>
                        <div class="card-body">
                            <form action="/actualizar_contrasena/<%= data.idusuario %>" method="post">
                                <div class="form-group row"> 
                                    <div class="col-md-12">
                                        <label class="mt-3" for="nombre">Nombre Usuario:</label>
                                        <input class="form-control col-md-10" id="nombre" name="nombre" value="<%= data.nombre %>" maxlength="20" required>
                                    </div>
                                </div>
                                <div class="form-group row mt-2">
                                    <div class="col-md-12">
                                        <label class="mt-3" for="passwordAnterior">Contraseña Anterior:</label>
                                        <input class="form-control col-md-10" type="password" id="passwordAnterior" name="passwordAnterior" maxlength="20" required>
                                    </div>
                                </div>
                                <div class="form-group row mt-2">
                                    <div class="col-md-12">
                                        <label class="mt-3" for="passwordNuevo1">Contraseña Nueva:</label>
                                        <input class="form-control col-md-10" type="password" id="passwordNuevo1" name="passwordNuevo1" maxlength="20" required>
                                    </div>
                                </div>
                                <div class="form-group row mt-2">
                                    <div class="col-md-12">
                                        <label class="mt-3" for="passwordNuevo2">Confirmar Contraseña Nueva:</label>
                                        <input class="form-control col-md-10" type="password" id="passwordNuevo2" name="passwordNuevo2" maxlength="20" required>
                                    </div>
                                </div>

                                <div class="alineacionCentrada">
                                    <button id="btnActualizar" type="submit" class="btn btn-primary row mt-2" disabled>Guardar</button>
                                </div>
                                
                            </form>
                        </div>
                    </div>
                </div>
                <div class="form-group col-md-3">
                
                </div>
            </div>
        </div>
        <% } %>


        
       
        <script>
            limitarCaracteres(document.getElementById("nombre"), 20);
            limitarCaracteres(document.getElementById("passwordAnterior"), 20);
            limitarCaracteres(document.getElementById("passwordNuevo1"), 20);
            limitarCaracteres(document.getElementById("passwordNuevo2"), 20);

            limitarCaracteresMin(document.getElementById("nombre"), 8);
            limitarCaracteresMin(document.getElementById("passwordAnterior"), 8);
            limitarCaracteresMin(document.getElementById("passwordNuevo1"), 8);
            limitarCaracteresMin(document.getElementById("passwordNuevo2"), 8);



            function limitarCaracteres(input, maxlength){
                input.addEventListener("input", () => {
                    if(input.value.length > maxlength){
                        input.value = input.value.slice(0, maxlength);
                    }
                });
            }


            function limitarCaracteresMin(input, minlength){
                input.addEventListener("input", () => {
                    let inputNombre = document.getElementById("nombre");
                    let inputPasswordAnterior = document.getElementById("passwordAnterior");
                    let inputPasswordNuevo1 = document.getElementById("passwordNuevo1");
                    let inputPasswordNuevo2 = document.getElementById("passwordNuevo2");

                    if(inputNombre.value.length >= minlength && inputPasswordAnterior.value.length >= minlength && inputPasswordNuevo1.value.length >= minlength && inputPasswordNuevo2.value.length >= minlength){
                        document.getElementById("btnActualizar").disabled = false;
                    }else if(inputNombre.value.length < minlength || inputPasswordAnterior.value.length < minlength || inputPasswordNuevo1.value.length >= minlength || inputPasswordNuevo2.value.length >= minlength){
                        document.getElementById("btnActualizar").disabled = true;
                    }
                });
            }
        </script>       
        
       
        
    </body>
</html>