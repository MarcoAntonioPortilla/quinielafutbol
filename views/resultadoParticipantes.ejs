<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Resultados Participantes</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body class="body-resultados-participantes">
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <%- include('partials/_header') %>
        <%}%>

        
        <div class="container"> <!--container-fluid-->
            <form action="/verResultados" method="post">
                <div class="form-group row mt-2">
                    <div class="col-md-3">

                    </div>
                    <div class="col-md-6">
                        <label class="mt-3 fw-bold" for="evento">Evento:</label>
                        <select class="form-control col-md-12" name="evento" required>
                            <option value=""> </option>
                            <% if(eventos){ 
                                for(var i = 0; i < eventos.length; i++){ %>
                                    <option value="<%= eventos[i].idevento %>"><%= eventos[i].nombre %></option>
                                <% } %>    
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3">

                    </div>
                </div>
                <div class="alineacionCentrada">
                    <input class="btn btn-primary mt-3" type="submit" value="Buscar">
                </div>
            </form>

            <div class="row mt-5">
                <div class="col-md-2">

                </div>

                <% if(process.env.EVENTO_SEL_NOMBRE != ""){ %>
                    <div class="col-md-8">
                        <div class="alineacionCentrada">
                            <center>
                                <% if(eventos){ 
                                    for(var i = 0; i < eventos.length; i++){ 
                                        if(eventos[i].nombre === process.env.EVENTO_SEL_NOMBRE){ %>
                                            <img class="tamanoLogo" src="../assets/img/<%= eventos[i].archivo %>" alt="logo">
                                        <% } %>
                                    <% } %>
                                <% } %>        
                                <strong><h2><%- process.env.EVENTO_SEL_NOMBRE%></h2></strong>
                            </center>
                        </div>
                    </div>
                <% } %>

                <div class="col-md-2">

                </div>
                
            </div>
            
            <div class="row">
                <div class="col-md-2">
                    
                </div>
                <div class="col-md-8 col-sm-8 col-xs-8">
                    <div class="table-responsive">  
                        <% if(typeof data != 'undefined'){ %>
                            <table class="table table-striped table-hover table-sm"> 
                                <thead class="table-dark text-center">
                                    <tr>
                                        <th>Participante</th>
                                        <th>Grupo</th>
                                        <th>Fecha</th>
                                        <th>Equipo</th>
                                        <th>Goles</th>
                                        <th></th>
                                        <th>Goles</th>
                                        <th>Equipo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                        <%for(var i = 0; i < data.length; i++){ %>
                                            <tr>
                                                <td class="textoUsuario" style="color: blue;"><%= data[i].usuarionombre %></td>
                                                <td class="textoGrupo text-danger"> <%= data[i].grupo %> </td>
                                                <td class="text-primary fw-bold">
                                                    <center>
                                                        <%= data[i].fecha.toLocaleDateString() %> <!--es-MX-->
                                                        <br>
                                                        <%= data[i].hora %> hrs.
                                                    </center> 
                                                </td> 
                                                <td>
                                                    <center>
                                                        <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo1 %>" alt="logo">
                                                        <br>
                                                        <strong> <%= data[i].nombre1 %> </strong>
                                                    </center>
                                                </td>
                                                <td class="textoMarcador" style="color: green">
                                                    <%= data[i].quinequipo1 %>
                                                </td>
                                                <td>
                                                    <img src="../assets/img/vs3.png" width="100" alt="logo">
                                                </td>
                                                <td class="textoMarcador" style="color: green">
                                                    <%= data[i].quinequipo2 %>
                                                </td>
                                                <td> 
                                                    <center>
                                                        <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo2 %>" alt="logo"> 
                                                        <br>
                                                        <strong> <%= data[i].nombre2 %> </strong>
                                                    </center>
                                                </td>
                                            </tr>
                                        <% } %>
                                </tbody>
                            </table>
                        <% } %>    
                    </div>
                </div>
                <div class="col-md-2">
                    
                </div>
            </div>
        </div>
    </body>
</html>