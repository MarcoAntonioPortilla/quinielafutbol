<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
        <title>Edición Usuario</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body>
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <script>
                window.location.href = "/inicio";
            </script>
        <%}%> 


        <% if(process.env.MENSAJE !== ''){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- process.env.MENSAJE %>
            </div>
        <% } %>


        <% if(typeof usuario_Mod !=='undefined'){ %>
            <input id="banderaModal" name="banderaModal" type="hidden" value="Activo">
        <% }else { %>
            <input id="banderaModal" name="banderaModal" type="hidden" value="">
        <% } %>        


        
        <div class="container-fluid">
            <div class="row mt-5">
                <div class="col-md-3">

                </div>
                <div class="col-md-6">
                    <div class="table-responsive"> 
                        <table class="table table-striped table-hover"> <!--table-bordered table-hover-->
                            <thead class="table-dark text-center">
                                <tr>
                                    <th>No.</th>
                                    <th>Nombre</th>
                                    <th>Password</th>
                                    <th>Tipo</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(data){
                                    for(var i = 0; i < data.length; i++){ %>
                                        <tr>
                                            <td> <%= (i + 1) %> </td>
                                            <td> <%= data[i].nombre %> </td>
                                            <td> <%= data[i].password %> </td>
                                            <td> <%= data[i].tipo %> </td>
                                            <td>
                                                <div class="alineacionCentrada">
                                                    <a href="/actualizar_usuario/<%= data[i].idusuario %>" class="tamanoBoton btn btn-primary">Actualizar</a> 
                                                    <button class="botonEliminar tamanoBoton btn btn-danger" id="<%= data[i].idusuario %>">Eliminar</button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-3">
                    
                </div>
            </div>
        </div>        




        
        <!-- Modal -->
        <% if(typeof usuario_Mod !=='undefined'){ %>

        <form action="/registrar_cambios/<%= usuario_Mod.idusuario %>" method="POST" >
            <div class="modal fade" id="ModalEditarUsuario" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5" id="exampleModalLabel">Editar Usuario</h1>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="form-group col-sm-4">
                                    <input class="form-control mr-sm-2 mt-3" name="idusuario" value="<%= usuario_Mod.idusuario %>" readonly>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-sm-12">
                                    <input class="form-control mr-sm-2 mt-3" id="nombre" name="nombre" placeholder="Nombre" value="<%= usuario_Mod.nombre %>" minlength="8" maxlength="20" required>
                                </div>
                            </div>
                            <div class="row">    
                                <div class="form-group col-sm-12">
                                    <input class="form-control mr-sm-2 mt-3" id="password" name="password" placeholder="Password" value="<%= usuario_Mod.password %>" minlength="8" maxlength="20" required>
                                </div>
                            </div>
                            <div class="row">        
                                <div class="form-group col-sm-12">
                                    <select class="form-control col-md-12 mt-3" name="tipo" placeholder="Tipo Usuario" required>
                                        <option value=""></option>
                                        <option value="usuario">Usuario</option>
                                        <option value="admin">Administrador</option>
                                        <option value="bloqueado">Bloqueado</option>
                                    </select>
                                </div>
                            </div>  
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                            <button id="btnActualizar" type="submit" class="btn btn-primary">Actualizar</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
        
        <% } %>



        




        <script>
            $(document).ready(function() {
                var vBanderaModal = $("#banderaModal").val();

                if(vBanderaModal !== ""){ 
                    $('#ModalEditarUsuario').modal('toggle');
                }
            });    



            $('.botonEliminar').click(function(){
                var vIndice = $(this).attr("id");
                var vCadena = "<a href=" + "/eliminar_usuario/" + vIndice + ">Eliminar</a>";

                alertify.alert('Eliminar usuario', "¿Está seguro de eliminar este usuario? " + vCadena);
            });



            limitarCaracteresMax(document.getElementById("nombre"), 20);
            limitarCaracteresMax(document.getElementById("password"), 20);

            limitarCaracteresMin(document.getElementById("nombre"), 8);
            limitarCaracteresMin(document.getElementById("password"), 8);
            

            function limitarCaracteresMax(input, maxlength){
                input.addEventListener("input", () => {
                    if(input.value.length > maxlength){
                        input.value = input.value.slice(0, maxlength);
                    }
                });
            }


            function limitarCaracteresMin(input, minlength){
                input.addEventListener("input", () => {
                let inputNombre = document.getElementById("nombre");
                let inputPassword = document.getElementById("password");

                    if(inputNombre.value.length >= minlength && inputPassword.value.length >= minlength){
                        document.getElementById("btnActualizar").disabled = false;
                    }else if(inputNombre.value.length < minlength || inputPassword.value.length < minlength){
                        document.getElementById("btnActualizar").disabled = true;
                    }
                });
            }
            
        
        </script>


        
    </body>
</html>