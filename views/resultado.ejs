<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Capturar Resultados</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body>
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <%- include('partials/_header') %>
        <%}%>


        <% if(typeof mensaje !== 'undefined'){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- mensaje %>
            </div>
        <% } %>

        
        <div class="container-fluid">
            <form action="/mostrarPartidos" method="post">
                <div class="form-group row mt-2">
                    <div class="col-md-3">

                    </div>
                    <div class="col-md-6">
                        <label class="mt-3" for="evento">Evento:</label>
                        <select class="form-control col-md-12" name="evento" required>
                            <option value=""> </option>
                            <% if(eventos){ 
                                for(var i = 0; i < eventos.length; i++){ %>
                                    <option value="<%= eventos[i].idevento %>"><%= eventos[i].nombre %></option>
                                <% } %>    
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3">

                    </div>
                </div>
                <div class="alineacionCentrada">
                    <input class="btn btn-primary mt-3" type="submit" value="Buscar">
                </div>
            </form>

            <div class="row mt-5">
                <div class="col-md-2">

                </div>
                <div class="col-md-8">
                    <div class="alineacionCentrada">
                        <div class="alert alert-light" role="alert"> 
                            <strong><h2><%- process.env.EVENTO_SEL_NOMBRE%></h2></strong>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">

                </div>
                
            </div>


            <input id="botonGuardar" class="tamanoBoton2 btn btn-primary mb-3 mx-auto d-block" type="button" value="Guardar">
            
            <div class="row">
                <div class="col-md-2">
                    
                </div>
                <div class="col-md-8">
                    <div class="table-responsive"> 
                        <table class="table table-striped table-hover">
                            <thead class="table-dark text-center">
                                <tr>
                                    <th>Grupo</th>
                                    <th>Fecha</th>
                                    <th>Equipo</th>
                                    <th>Goles</th>
                                    <th></th>
                                    <th>Goles</th>
                                    <th>Equipo</th>
                                </tr>
                            </thead>
                            <tbody>
                                <form id="formResultados" action="/guardarResultados" method="post">
                                    <% if(typeof data != 'undefined'){ %>
                                        <input name="evento" value="<%= data[0].evento %>" type="hidden">

                                        <%for(var i = 0; i < data.length; i++){ %>
                                            <tr>
                                                <td class="textoGrupo"> <%= data[i].grupo %> </td>
                                                <td>
                                                    <center>
                                                        <%= data[i].fecha.toLocaleDateString() %> <!--es-MX-->
                                                        <br>
                                                        <%= data[i].hora %> hrs.
                                                        <input name="P_<%= data[i].idpartido %>" value="<%= data[i].idpartido %>" type="hidden">
                                                    </center> 
                                                </td> 
                                                <td>
                                                    <center>
                                                        <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo1 %>" alt="logo">
                                                        <br>
                                                        <strong> <%= data[i].nombre1 %> </strong>
                                                    </center>
                                                </td>
                                                <td>
                                                    <input class="inputMarcador form-control mr-sm-4" name="Eq_1_<%= data[i].idpartido %>" onkeypress="comprueba(this)" onblur="comprueba(this)" type="number" min="0" pattern="^[0-9]+" value="<%= data[i].resequipo1 %>">
                                                </td>
                                                <td>
                                                    <img src="../assets/img/vs3.png" width="80" alt="logo">
                                                </td>
                                                <td>
                                                    <input class="inputMarcador form-control mr-sm-4" name="Eq_2_<%= data[i].idpartido %>" onkeypress="comprueba(this)" onblur="comprueba(this)" type="number" min="0" pattern="^[0-9]+" value="<%= data[i].resequipo2 %>">
                                                </td>
                                                <td> 
                                                    <center>
                                                        <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo2 %>" alt="logo"> 
                                                        <br>
                                                        <strong> <%= data[i].nombre2 %> </strong>
                                                    </center>
                                                </td>
                                            </tr>
                                        <% } %>
                                    <% } %>
                                    <!--<button id="guardarQuin" type="submit" class="tamanoBoton2 btn btn-primary mb-3 mx-auto d-block">Guardar</button>-->
                                    
                                </form> 
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-2">
                    
                </div>
            </div>
        </div>
        
        

        <script src="./assets/js/resultado.js"></script>  
    </body>
</html>