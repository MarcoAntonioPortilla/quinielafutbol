<!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Eliminar Evento</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body>
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <script>
                window.location.href = "/inicio";
            </script>
        <%}%>   

        
        <% if(typeof borrado !== 'undefined'){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- borrado %>
            </div>
        <% } %>



        
        <div class="container">
            <div class="row mt-5">
                <div class="col-md-3">

                </div>
                <div class="col-md-6">
                    <div class="table-responsive"> 
                        <table class="table table-striped table-hover">
                            <thead class="table-dark text-center">
                                <tr>
                                    <th>Id</th>
                                    <th>Nombre</th>
                                    <th>Estatus</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(data){
                                    for(var i = 0; i < data.length; i++){ %>
                                        <tr>
                                            <td> <%= data[i].idevento %> </td>
                                            <td> <%= data[i].nombre %> </td>
                                            <td> <%= data[i].estatus %> </td>
                                            <td>
                                                <button class="botonEliminar tamanoBoton btn btn-danger" id="<%= data[i].idevento %>">Eliminar</button>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="col-md-3">
                    
                </div>
            </div>
        </div>



        <script>
            $('.botonEliminar').click(function(){
                var vIndice = $(this).attr("id");
                var vCadena = "<a href=" + "/eliminar_evento/" + vIndice + ">Eliminar</a>";

                alertify.alert('Eliminar evento', "¿Está seguro de eliminar este evento? " + vCadena);
            });
        </script>


    </body>
</html>