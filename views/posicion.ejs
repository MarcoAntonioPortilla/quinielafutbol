<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Tabla de Posiciones</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body class="body-posiciones">
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <%- include('partials/_header') %>
        <%}%>


           
        <div class="container">
            <form action="/verPosiciones" method="post">
                <div class="form-group row mt-2">
                    <div class="col-md-3">

                    </div>
                    <div class="col-md-6">
                        <label class="mt-3 text-primary fw-bold" for="evento">Evento:</label>
                        <select class="form-control col-md-12" name="evento" required>
                            <option value=""> </option>
                            <% if(eventos){ 
                                for(var i = 0; i < eventos.length; i++){ %>
                                    <option value="<%= eventos[i].idevento %>"><%= eventos[i].nombre %></option>
                                <% } %>    
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3">

                    </div>
                </div>
                <div class="alineacionCentrada">
                    <input class="btn btn-primary mt-3" type="submit" value="Buscar">
                </div>
            </form>

            <div class="row mt-5">
                <div class="col-md-2">

                </div>

                <% if(process.env.EVENTO_SEL_NOMBRE != ""){ %>
                    <div class="col-md-8">
                        <div class="alineacionCentrada">
                            <center>
                                <% if(eventos){ 
                                    for(var i = 0; i < eventos.length; i++){ 
                                        if(eventos[i].nombre === process.env.EVENTO_SEL_NOMBRE){ %>
                                            <img class="tamanoLogo" src="../assets/img/<%= eventos[i].archivo %>" alt="logo">
                                        <% } %>
                                    <% } %>
                                <% } %>        
                                <strong><h2><%- process.env.EVENTO_SEL_NOMBRE%></h2></strong>
                            </center>
                        </div>
                    </div>
                <% } %>

                <div class="col-md-2">

                </div>
                
            </div>
            
            <div class="row">
                <div class="col-md-2">
                    
                </div>
                <div class="col-md-8">
                    <div class="table-responsive">  
                        <% if(typeof data != 'undefined'){ %> 
                            <table class="table table-striped table-hover">
                                <thead class="table-dark text-center">
                                    <tr>
                                        <th>Posición</th>
                                        <th>Nombre</th>
                                        <th>Puntos</th>
                                    </tr>
                                </thead>
                        <% } %>        
                                <tbody>
                                    <% if(typeof data != 'undefined'){
                                        let varPosicion = 0;

                                      for(let i = 0; i < data.length; i++){ 
                                            if(i === 0){
                                                varPosicion = varPosicion + 1;
                                            }else if(i > 0 && i <= data.length){
                                                if(data[i].total !== data[i - 1].total){
                                                    varPosicion = varPosicion + 1;
                                                }
                                            }
                                    %>
                                            <tr>
                                                <td class="textoGrupo"> 
                                                    <% if(varPosicion === 1){ %>
                                                        <img src="../assets/img/primer_lugar.png" width="80" alt="logo">
                                                    <% }else if(varPosicion === 2){ %>
                                                        <img src="../assets/img/segundo_lugar.png" width="80" alt="logo">
                                                    <% }else if(varPosicion === 3){ %>    
                                                        <img src="../assets/img/tercer_lugar.png" width="80" alt="logo">
                                                    <% }else{ %>
                                                        <%= varPosicion %>    
                                                    <% } %>    
                                                </td>
                                                <td class="textoGrupo">
                                                    <%= data[i].nombre %>
                                                </td>
                                                <td class="textoGrupo">
                                                    <%= data[i].total %>
                                                </td>
                                            </tr>
                                        <% } %>
                                    <% } %>
                                </tbody>
                            </table>
                       
                    </div>
                </div>
                <div class="col-md-2">
                    
                </div>
            </div>
        </div>
    </body>
</html>