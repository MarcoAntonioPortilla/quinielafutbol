<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Quiniela</title>
        <link rel="shortcut icon" href="assets/img/balon.png">
    </head>
    <body class="body-quiniela-total">
        <% if(process.env.TIPO_USUARIO === "admin"){ %>
            <%- include('partials/_header-admin') %>
        <%}else{%>    
            <%- include('partials/_header') %>
        <%}%>


        <% if(typeof mensaje !== 'undefined'){ %>
            <div class="alert alert-primary" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <strong>Mensaje: </strong><%- mensaje %>
            </div>
        <% } %>

        
        <div class="container"> <!--container-fluid-->
            <form action="/mostrar_quinielaTotal" method="post">
                <div class="form-group row mt-2">
                    <div class="col-md-3">

                    </div>
                    <div class="col-md-6">
                        <label class="mt-3 text-primary fw-bold" for="evento"><strong>Evento:</strong></label>
                        <select class="form-control col-md-12" name="evento" required>
                            <option value=""> </option>
                            <% if(eventos){ 
                                for(var i = 0; i < eventos.length; i++){ %>
                                    <option value="<%= eventos[i].idevento %>"><%= eventos[i].nombre %></option>
                                <% } %>    
                            <% } %>
                        </select>
                    </div>
                    <div class="col-md-3">

                    </div>
                </div>
                <div class="alineacionCentrada">
                    <input class="btn btn-primary mt-3" type="submit" value="Buscar">
                </div>
            </form>

            <div class="row mt-5">
                <div class="col-md-2">

                </div>

                <% if(process.env.EVENTO_SEL_NOMBRE != ""){ %>
                    <div class="col-md-8">
                        <div class="alineacionCentrada">
                            <center>
                                <% if(eventos){ 
                                    for(var i = 0; i < eventos.length; i++){ 
                                        if(eventos[i].nombre === process.env.EVENTO_SEL_NOMBRE){ %>
                                            <img class="tamanoLogo" src="../assets/img/<%= eventos[i].archivo %>" alt="logo">
                                        <% } %>
                                    <% } %>
                                <% } %>        
                                <strong><h2><%- process.env.EVENTO_SEL_NOMBRE%></h2></strong>
                            </center>
                        </div>
                    </div>
                <% } %>

                <div class="col-md-2">

                </div>
                
            </div>

            <% if(typeof data !== 'undefined'){   %>
                <input id="botonGuardar" class="tamanoBoton2 btn btn-primary mb-3 mx-auto d-block" type="button" value="Guardar"> 
            <% } %>   

            <div class="row">
                <div class="col-md-2">
                    
                </div>
                <div class="col-md-8 col-sm-8 col-xs-8">
                    <div class="table-responsive">  
                        <% if(typeof data !== 'undefined'){   %>
                            <table class="table table-striped table-hover">
                                <thead class="table-dark text-center">
                                    <tr>
                                        <th>Grupo</th>
                                        <th>Fecha</th>
                                        <th>Equipo</th>
                                        <th>Goles</th>
                                        <th></th>
                                        <th>Goles</th>
                                        <th>Equipo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <form id="formQuiniela" action="/guardar_quinielaTotal" method="post">
                                            <input name="evento" value="<%= data[0].evento %>" type="hidden">

                                            <%for(var i = 0; i < data.length; i++){ %>
                                                <tr>
                                                    <td class="textoGrupo text-danger"> <%= data[i].grupo %> </td>
                                                    <td class="text-primary fw-bold">
                                                        <center>
                                                            <%= data[i].fecha.toLocaleDateString('es-MX') %> <!--es-MX-->
                                                            <br>
                                                            <%= data[i].hora %> hrs.
                                                            <input name="P_<%= data[i].idpartido %>" value="<%= data[i].idpartido %>" type="hidden">
                                                        </center> 
                                                    </td> 
                                                    <td>
                                                        <center>
                                                            <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo1 %>" alt="logo">
                                                            <br>
                                                            <strong> <%= data[i].nombre1 %> </strong>
                                                        </center>
                                                    </td>
                                                    <td><!--es-MX--> <!--en-US-->
                                                        <%  let fechaActual = new Date();
                                                            let fechaActual2 = fechaActual.toLocaleString("en-US", {timeZone: 'America/Mexico_City'});
                                                            let fechaActual3 = new Date(fechaActual2);

                                                            let fechaPartido = new Date(data[i].fecha);
                                                            let fechaPartido2 = fechaPartido.toLocaleString("en-US", {timeZone: 'America/Mexico_City'});
                                                            let fechaPartido3 = fechaPartido2.slice(0, 10);
                                                            let fechaPartido4 = fechaPartido3 + ", " + data[i].hora;
                                                            let fechaPartido5 = new Date(fechaPartido4);
                                                        
                                                            if(fechaActual3 < fechaPartido5){ %>
                                                                <input class="inputMarcador form-control mr-sm-4" name="Eq_1_<%= data[i].idpartido %>" onkeypress="comprueba(this)" onblur="comprueba(this)" type="number" min="0" pattern="^[0-9]+" value="<%= data[i].quinequipo1 %>" >
                                                            <% }else{ %>    
                                                                <input class="inputDeshabilitado inputMarcador form-control mr-sm-4" name="Eq_1_<%= data[i].idpartido %>" value="<%= data[i].quinequipo1 %>" readonly >  <!--onkeypress="comprueba(this)" onblur="comprueba(this)" type="number" min="0" pattern="^[0-9]+"-->
                                                            <% } %>    
                                                    </td>
                                                    <td>
                                                        <img src="../assets/img/vs3.png" width="100" alt="logo">
                                                    </td>
                                                    <td>
                                                        <%  if(fechaActual3 < fechaPartido5){ %>
                                                                <input class="inputMarcador form-control mr-sm-4" name="Eq_2_<%= data[i].idpartido %>" onkeypress="comprueba(this)" onblur="comprueba(this)" type="number" min="0" pattern="^[0-9]+" value="<%= data[i].quinequipo2 %>">
                                                            <% }else{ %>    
                                                                <input class="inputDeshabilitado inputMarcador form-control mr-sm-4" name="Eq_2_<%= data[i].idpartido %>" value="<%= data[i].quinequipo2 %>" readonly >
                                                            <% } %>    

                                                            <input name="FechaPartido_<%= data[i].idpartido %>" value="<%= fechaPartido5 %>" type="hidden">
                                                    </td>
                                                    <td> 
                                                        <center>
                                                            <img class="tamanoImagen" src="../assets/img/<%= data[i].archivo2 %>" alt="logo"> 
                                                            <br>
                                                            <strong> <%= data[i].nombre2 %> </strong>
                                                        </center>
                                                    </td>
                                                </tr>
                                            <% } %> 
                                    </form> 
                                </tbody>
                            </table>
                        <% } %>    
                    </div>
                </div>
                <div class="col-md-2">
                    
                </div>
            </div>
        </div>
        
        

        <script src="./assets/js/quiniela.js"></script>  
    </body>
</html>