<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>

        <script src="https://code.jquery.com/jquery-3.4.1.js"></script>
        <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script> 

        <link href="assets/css/formato.css" rel="stylesheet">
        
        <title>Logueo</title>
        <link rel="shortcut icon" href="assets/img/balon.png">

        <script>
            $(document).ready(function(){
                setTimeout(function(){ 
                    $("#ModalLogin").modal("show");
                }, 3000);

                $('#ModalLogin').modal({backdrop: 'static', keyboard: false});
            });
        </script>
    </head>
    <body class="body-login">
        

        <!-- Modal -->
        <div class="modal fade" id="ModalLogin" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="exampleModalLabel">Bienvenido</h1>
                        <br> 
                    </div>
                    <div class="modal-body">
                        <% if(typeof error !== 'undefined'){ %>
                            <div class="alert alert-danger" role="alert">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                                </svg>
                                <strong>Error: </strong><%- error %>
                            </div>
                        <% } %>

                        <form action="/login" method="POST" >
                            <input class="form-control mr-sm-2 mt-3" type="text" id="login" name="login" placeholder="Usuario" maxlength="20">
                            <input class="form-control mr-sm-2 mt-3" type="password" id="loginPassword" name="loginPassword" placeholder="Password" maxlength="20">
                            <input class="form-control mr-sm-2 mt-3" type="text" id="concurso" name="concurso" placeholder="Concurso" maxlength="20">
                            <div class="alineacionCentrada">
                                <input class="btn btn-primary mt-3" type="submit" value="Aceptar">
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>



        <script src="./assets/js/login.js"></script>     
    </body>
</html>